# Copy this file to terraform.tfvars and fill in real values.
# terraform.tfvars is gitignored — never commit real credentials.

aws_region        = "ap-south-1"
project           = "veloshelf"
environment       = "prod"

# Unique suffix for S3 bucket names — use your AWS account ID
# (bucket names are global; this prevents collisions)
s3_suffix         = "123456789012"

# EC2 key pair name as it appears in AWS Console → EC2 → Key Pairs
ec2_key_name      = "veloshelf-key"
ec2_instance_type = "t3.small"

# RDS
rds_instance_class = "db.t3.micro"
db_name            = "veloshelf"
db_username        = "veloshelf"
db_password        = "change-me-before-apply"

# VPC
vpc_cidr = "10.0.0.0/16"
